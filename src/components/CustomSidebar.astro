---
// src/components/CustomSidebar.astro

// 1. 直接拿到 Starlight 传给侧边栏的全量树状数据
const { sidebar } = Astro.locals.starlightRoute;
import { Icon } from '@astrojs/starlight/components';

// 🌟 递归工具函数：判断某个第一层节点（不管是 group 还是直接是当前 link）是否处于激活状态
function isCategoryActive(entry) {
  if (entry.isCurrent) return true;
  if (entry.type === 'group' && entry.entries) {
    return entry.entries.some(subEntry => isCategoryActive(subEntry));
  }
  return false;
}

// 2. 找到当前正在浏览的页面属于顶层的哪个“分类导航”
const activeTopCategory = sidebar.find(entry => isCategoryActive(entry)) || sidebar[0];

// 🌟 新增工具函数：深度优先递归，拿到某个分类下最深处的第一个有效链接
function getFirstLeafHref(entry) {
  if (entry.type === 'link') return entry.href;
  if (entry.type === 'group' && entry.entries && entry.entries.length > 0) {
    return getFirstLeafHref(entry.entries[0]); // 递归找第一项
  }
  return '#'; // 实在没有兜底
}

// 3. 计算下方侧边栏要渲染的数据：如果有子集就用子集，如果本身就是叶子 link（没有子集）就置空
const subSidebarData = (activeTopCategory && activeTopCategory.type === 'group') ? activeTopCategory.entries : [];
---

<div class="custom-layout-container">
  
  {/* 🏢 上半部分：分类导航区（对应 sidebar 的第一层，如概述、角色） */}
  {/* 🏢 上半部分：分类导航区（对应 sidebar 的第一层，如概述、角色） */}
  <div class="top-category-nav">
    <ul class="category-list">
      {
        sidebar.map((category) => {
          const isActive = isCategoryActive(category);
          
          // 🌟 统一动态获取跳转链接：如果是 link 直接用 href，如果是 group 递归进去找第一个有页面的子项
          const targetHref = category.type === 'link' ? category.href : getFirstLeafHref(category);
          
          return (
            <li class={`category-item ${isActive ? 'active-cat' : ''}`}>
              <a href={targetHref} aria-current={category.isCurrent ? 'page' : undefined}>
                <span>{category.label}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>

  <hr class="nav-divider" />

  {/* 🗂️ 下半部分：具体的侧边栏内容区（根据上方所选分类动态渲染，支持无限层级嵌套） */}
  <div class="bottom-sidebar-content">
    <ul class="sidebar-entries">
      {
        subSidebarData.length > 0 ? (
          subSidebarData.map((entry) => {
            
            // ---------- 🌲 如果这层是普通的叶子链接 ----------
            if (entry.type === 'link') {
              const imgIconSrc = entry.attrs?.['data-icon'];
              return (
                <li class="sidebar-leaf">
                  <a href={entry.href} aria-current={entry.isCurrent ? 'page' : undefined} class={[entry.isCurrent ? 'current' : '', imgIconSrc ? 'with-image' : ''].join(' ')} {...entry.attrs}>
                    {imgIconSrc && <img src={imgIconSrc} class="sidebar-custom-img-icon" alt="" />}
                    <span>{entry.label}</span>
                    {entry.badge && <span class={`custom-badge ${entry.badge.variant}`}>{entry.badge.text}</span>}
                  </a>
                </li>
              );
            }

            // ---------- 📂 如果这层是分组折叠菜单 (如: 暗影眷属、奥林匹斯山众神) ----------
            if (entry.type === 'group') {
              return (
                <li class="sidebar-group">
                  <details open={!entry.collapsed}>
                    <summary>
                      <span class="group-heading">{entry.label}</span>
                      <Icon name="down-caret" class="caret" size="1.25rem" />                  
                    </summary>
                    
                    {/* 渲染三层或更深层的子链接 (支持带图标的墨利诺厄等) */}
                    <ul class="sidebar-sub-entries">
                      {entry.entries.map((subEntry) => {
                        if (subEntry.type === 'link') {
                          const subImgSrc = subEntry.attrs?.['data-icon'];
                          return (
                            <li>
                              <a href={subEntry.href} aria-current={subEntry.isCurrent ? 'page' : undefined} class={[subEntry.isCurrent ? 'current' : '', 'lv2-sidebar', subImgSrc ? 'with-image' : ''].join(' ')} {...subEntry.attrs}>
                                {subImgSrc && <img src={subImgSrc} class="sidebar-custom-img-icon" alt="" />}
                                <span>{subEntry.label}</span>
                                {subEntry.badge && <span class={`custom-badge ${subEntry.badge.variant}`}>{subEntry.badge.text}</span>}
                              </a>
                            </li>
                          );
                        }
                        return null;
                      })}
                    </ul>
                  </details>
                </li>
              );
            }
            return null;
          })
        ) : (
          // 如果当前分类没有子项（例如点击了“概述”），给个漂亮的友好提示或置空
          <li class="sidebar-empty-tip">暂无子分类目录</li>
        )
      }
    </ul>
  </div>
</div>

<style>
  /* 🎛️ 整体大容器：纵向Flex布局，高度占满 Starlight 侧边栏 */
  .custom-layout-container {
    display: flex;
    flex-direction: column;
    height: calc(100vh - var(--sl-nav-height) - 3rem); /* 减去顶部导航和内边距 */
  }

  /* 🏢 1. 上部：分类导航区 */
  .top-category-nav {
    max-height: 40%; /* 固定大高 */
    overflow-y: auto;  /* 超出 X 轴不动，Y 轴自动滚动 */
    padding-right: 4px;
    flex-shrink: 0;    /* 锁死不让下半部分挤压它 */
  }
  
  .category-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .category-item a {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--sl-color-gray-3);
    text-decoration: none;
    border-radius: 0.375rem;
    font-size: var(--sl-text-base);
    font-weight: 600;
    transition: all 0.15s ease;
  }

  .category-item a:hover {
    background-color: var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }

  /* 选中的大分类高亮样式 */
  .category-item.active-cat a {
    background-color: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    border-left: 4px solid var(--sl-color-accent);
    padding-left: calc(0.75rem - 4px);
  }

  /* 分割线 */
  .nav-divider {
    border: 0;
    border-top: 1px solid var(--sl-color-gray-5);
    margin: 1rem 0;
    flex-shrink: 0;
  }

  /* 🗂️ 2. 下部：侧边栏独立滚动区 */
  .bottom-sidebar-content {
    flex-grow: 1;     /* 充满剩余所有高度 */
    overflow-y: auto; /* 独立 Y 轴滚动 */
    padding-right: 4px;
  }

  /* 基础列表复位 */
  .custom-layout-container ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .custom-layout-container li {
    margin-top: 0.35rem;
  }
  
  .bottom-sidebar-content a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--sl-color-gray-3);
    padding: 0.4rem 0.6rem;
    border-radius: 0.25rem;
    font-size: var(--sl-text-sm);
    transition: background-color 0.15s ease;
  }
  
  .bottom-sidebar-content a:hover {
    background-color: var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }
  
  /* 当前高亮页面样式 */
  .bottom-sidebar-content a.current {
    color: var(--sl-color-text-invert);
    background-color: var(--sl-color-text-accent);
    font-weight: 600;
  }
  
  /* 🌟 核心：图片图标的大小控制 */
  .sidebar-custom-img-icon {
    width: 24px;   /* 降级到正常侧边栏图标尺寸，如果是大图你可以自己改大 */
    height: 24px;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* 分组（Group）菜单样式 */
  .sidebar-group {
    margin-top: 1rem !important;
  }
  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 0.6rem;
    cursor: pointer;
    user-select: none;
  }
  .group-heading {
    font-size: var(--sl-text-sm);
    font-weight: 600;
    color: var(--sl-color-white);
    letter-spacing: 0.05em;
  }
  .caret {
    color: var(--sl-color-gray-3);
    transition: transform 0.2s ease;
  }
  details[open] summary .caret {
    transform: rotateZ(-180deg);
  }
  .sidebar-sub-entries {
    padding-left: 0.75rem !important;
    border-left: 1px solid var(--sl-color-gray-5);
    margin-left: 0.6rem !important;
    margin-top: 0.25rem !important;
  }

  .sidebar-empty-tip {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-4);
    text-align: center;
    padding-top: 2rem;
    font-style: italic;
  }

  /* 徽章样式 */
  .custom-badge {
    padding: 0.15rem 0.4rem;
    font-size: var(--sl-text-xs);
    border-radius: 0.25rem;
    line-height: 1;
    margin-left: auto;
  }
</style>