---
// R2Image.astro
import globalConfig from '../../configs/globalConfigs.mjs'

const {
  src = "",
  size = 'medium',
  sizeNum = null,
  ...attrs
} = Astro.props

// 🌟 核心：清理 src 开头的斜杠，防止拼接出双斜杠
const cleanSrc = src.startsWith('/') ? src.slice(1) : src;

// 🌟 核心魔法：判断是否为开发环境 (npm run dev)
// 如果是开发环境，走本地 public/r2Sources 软链接路径
// 如果是生产环境 (build 线上环境)，依然走你原来的远程 CDN 域名
const isDev = import.meta.env.DEV;
const finalSrc = isDev 
  ? `/r2Sources/${cleanSrc}` 
  : `${globalConfig.hadesSourceHost}/${cleanSrc}`;

const classArr = [
  'r2-image',
  size
]
const style = [
  sizeNum !== null ? `width: ${sizeNum}px; height: ${sizeNum}px;` : ''
]
---

<img
  class={classArr.join(' ')}
  style={style.join(' ')}
  src={finalSrc}
  alt="" {...attrs}>

<style lang="scss">
  .r2-image {
    display: inline-block;
    &.mini {
      width: 22px;
      height: 22px;
    }
    &.small {
      width: 50px;
      height: 50px;
    }
    &.medium {
      width: 75px;
      height: 75px;
    }
    &.large {
      width: 100px;
      height: 100px;
    }
    &.xl {
      width: 130px;
      height: 130px;
    }
    &.xxl {
      width: 170px;
      height: 170px;
    }
  }
</style>